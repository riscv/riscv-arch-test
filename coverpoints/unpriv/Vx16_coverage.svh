covergroup Vx16_vrem_vx_cg with function sample(ins_t ins);
    option.per_instance = 0;
    //////////////////////////////////////////////////////////////////////////////////
    // cmp_vd_vs2
    //////////////////////////////////////////////////////////////////////////////////

