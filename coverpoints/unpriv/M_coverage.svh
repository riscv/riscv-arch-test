// ---------------------
`endif
function void m_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "div"     : begin
            M_div_cg.sample(ins);
        end
        "divu"     : begin
            M_divu_cg.sample(ins);
        end
        "mul"     : begin
            M_mul_cg.sample(ins);
        end
        "mulh"     : begin
            M_mulh_cg.sample(ins);
        end
        "mulhsu"     : begin
            M_mulhsu_cg.sample(ins);
        end
        "mulhu"     : begin
            M_mulhu_cg.sample(ins);
        end
        "rem"     : begin
            M_rem_cg.sample(ins);
        end
        "remu"     : begin
            M_remu_cg.sample(ins);
        end
`ifdef XLEN64
        "divuw"     : begin
            M_divuw_cg.sample(ins);
        end
        "divw"     : begin
            M_divw_cg.sample(ins);
        end
        "mulw"     : begin
            M_mulw_cg.sample(ins);
        end
        "remuw"     : begin
            M_remuw_cg.sample(ins);
        end
        "remw"     : begin
            M_remw_cg.sample(ins);
        end
`endif
    endcase
endfunction
