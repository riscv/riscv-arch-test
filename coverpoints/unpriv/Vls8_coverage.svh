        bins agnostic    = {1};
    }

    mask_enabled_agnostic: coverpoint ins.current.insn[25] {
        bins enabled = {1'b0};
    }

    cr_vtype_agnostic_e64 : cross cp_csr_vtype_vta,cp_csr_vtype_vma,mask_enabled_agnostic iff (ins.trap == 0 )  {
        // Cross coverage of vector tail and mask agnostic behaviors
    }

        //// end cr_vtype_agnostic_e64////////////////////////////////////////////////

endgroup
