function void zca_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "c.add"     : begin
            Zca_c_add_cg.sample(ins);
        end
        "c.addi"     : begin
            Zca_c_addi_cg.sample(ins);
        end
