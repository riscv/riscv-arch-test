            bins eighth  = {5};
        `endif
        `ifdef LMULf4_SUPPORTED
            bins fourth = {6};
        `endif

        // lmul 1/2 not supported for sew = 8 eew = 64
        // lmul 1 not supported for sew = 8 eew = 64
        // lmul 2 not supported for sew = 8 eew = 64
    }

    cp_csr_vl_edges : coverpoint vl_check(ins.hart, ins.issue)  iff (ins.trap == 0 )  {
        // Edges values of VL (vector length)
        bins one        = {vl_one       };
        bins vlmax      = {vl_vlmax     };
        bins legal      = {vl_legal     };
    }

    cr_vl_lmul_e64_emul2max_sew8 : cross cp_csr_vtype_lmul_all_le_8_e64_emul2max, cp_csr_vl_edges  iff (ins.trap == 0 & get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vsew") == 0)  {
