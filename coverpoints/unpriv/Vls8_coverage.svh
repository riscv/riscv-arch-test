covergroup Vls8_vloxseg5ei16_v_cg with function sample(ins_t ins);
    option.per_instance = 0;
    cp_asm_count : coverpoint ins.ins_str == "vloxseg5ei16.v"  iff (ins.trap == 0 )  {
