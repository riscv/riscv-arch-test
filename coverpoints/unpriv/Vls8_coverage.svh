    cr_vl_lmul_e64_sew8 : cross cp_csr_vtype_lmul_all_le_8_e64, cp_csr_vl_edges  iff (ins.trap == 0 & get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vsew") == 0)  {
