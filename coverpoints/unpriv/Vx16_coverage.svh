    //////////////////////////////////////////////////////////////////////////////////

    cp_vd_emul2 : coverpoint ins.get_vr_reg(ins.current.vd) iff (ins.trap == 0) {
        // VD register assignment (widening instruction, excluding odd registers)
        ignore_bins v1 = {v1};
        ignore_bins v3 = {v3};
        ignore_bins v5 = {v5};
        ignore_bins v7 = {v7};
        ignore_bins v9 = {v9};
        ignore_bins v11 = {v11};
        ignore_bins v13 = {v13};
