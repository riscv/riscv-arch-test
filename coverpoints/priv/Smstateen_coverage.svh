    }
`endif

    // ── Sctr-dependent coverpoints (cp_ctr) ──────────────────────────────
`ifdef SCTR_SUPPORTED
    ctr_state: coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_CURRENT, "mstateen0", "ctr") {
        bins ctr_disabled = {1'b0};
