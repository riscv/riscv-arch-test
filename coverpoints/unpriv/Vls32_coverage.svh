// ---------------------
function void vls32_sample(int hart, int issue, ins_t ins);

    if (get_csr_val(hart, issue, `SAMPLE_BEFORE, "vtype", "vsew") == 2) begin
        case (traceDataQ[hart][issue][0].inst_name)
            "vl1re16.v"     : begin
                Vls32_vl1re16_v_cg.sample(ins);
            end
            "vl1re32.v"     : begin
                Vls32_vl1re32_v_cg.sample(ins);
            end
            "vl1re64.v"     : begin
                Vls32_vl1re64_v_cg.sample(ins);
            end
            "vl1re8.v"     : begin
                Vls32_vl1re8_v_cg.sample(ins);
            end
            "vl2re16.v"     : begin
                Vls32_vl2re16_v_cg.sample(ins);
            end
            "vl2re32.v"     : begin
                Vls32_vl2re32_v_cg.sample(ins);
            end
            "vl2re64.v"     : begin
                Vls32_vl2re64_v_cg.sample(ins);
            end
            "vl2re8.v"     : begin
                Vls32_vl2re8_v_cg.sample(ins);
            end
            "vl4re16.v"     : begin
                Vls32_vl4re16_v_cg.sample(ins);
            end
            "vl4re32.v"     : begin
                Vls32_vl4re32_v_cg.sample(ins);
            end
            "vl4re64.v"     : begin
                Vls32_vl4re64_v_cg.sample(ins);
            end
            "vl4re8.v"     : begin
                Vls32_vl4re8_v_cg.sample(ins);
            end
            "vl8re16.v"     : begin
                Vls32_vl8re16_v_cg.sample(ins);
            end
            "vl8re32.v"     : begin
                Vls32_vl8re32_v_cg.sample(ins);
            end
            "vl8re64.v"     : begin
                Vls32_vl8re64_v_cg.sample(ins);
            end
            "vl8re8.v"     : begin
                Vls32_vl8re8_v_cg.sample(ins);
            end
            "vle16.v"     : begin
                Vls32_vle16_v_cg.sample(ins);
            end
            "vle16ff.v"     : begin
                Vls32_vle16ff_v_cg.sample(ins);
            end
            "vle32.v"     : begin
                Vls32_vle32_v_cg.sample(ins);
            end
            "vle32ff.v"     : begin
                Vls32_vle32ff_v_cg.sample(ins);
            end
            "vle64.v"     : begin
                Vls32_vle64_v_cg.sample(ins);
            end
            "vle64ff.v"     : begin
                Vls32_vle64ff_v_cg.sample(ins);
            end
            "vle8.v"     : begin
                Vls32_vle8_v_cg.sample(ins);
            end
            "vle8ff.v"     : begin
                Vls32_vle8ff_v_cg.sample(ins);
            end
            "vlm.v"     : begin
                Vls32_vlm_v_cg.sample(ins);
