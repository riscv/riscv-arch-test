        ignore_bins v23 = {v23};
        ignore_bins v25 = {v25};
        ignore_bins v27 = {v27};
        ignore_bins v29 = {v29};
        ignore_bins v31 = {v31};
    }

    //// end cp_vd_emul2////////////////////////////////////////////////

    cp_vl_0 : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") {
    bins zero = {0};
    }

