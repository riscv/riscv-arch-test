    }
    ctr_csrs: coverpoint ins.current.insn[31:20] {
        wildcard bins sctrdepth  = {CSR_SCTRDEPTH};
        wildcard bins sctrstatus = {CSR_SCTRSTATUS};
        // sctrl intentionally missing from coverage file
    }
`endif


    cp_csr_illegal_accesses: cross priv_mode_u, csr, csrrw;
    cp_walking_ones: cross csr, csrrw, csr_walk;

`ifdef ZFINX_SUPPORTED
    cp_fcsr: cross misa_F, mstateen0_fcsr_bit, csrrw, fscr_csr {
        ignore_bins ig1 = binsof(misa_F.F_set)  && binsof(mstateen0_fcsr_bit.fcsr_zero);
        ignore_bins ig2 = binsof(misa_F.F_set)  && binsof(fscr_csr.fcsr);
        ignore_bins ig3 = binsof(misa_F.F_clear) && binsof(mstateen0_fcsr_bit.fcsr_zero);
    }
    cp_fcsr_lower: cross priv_mode_s_u, misa_F, mstateen0_fcsr_bit, csrrw, fcsr_lower_mode_csrs {
        ignore_bins ig1 = binsof(misa_F.F_set)  && binsof(mstateen0_fcsr_bit.fcsr_zero);
        ignore_bins ig2 = binsof(misa_F.F_set)  && binsof(fscr_csr.fcsr);
        ignore_bins ig3 = binsof(misa_F.F_clear) && binsof(mstateen0_fcsr_bit.fcsr_zero);
    }
    cp_fcsr_lower_fp_instrs: cross priv_mode_s_u, misa_F, mstateen0_fcsr_bit, fp_instrs {
        ignore_bins ig1 = binsof(misa_F.F_set)  && binsof(mstateen0_fcsr_bit.fcsr_zero);
        ignore_bins ig2 = binsof(misa_F.F_clear) && binsof(mstateen0_fcsr_bit.fcsr_zero);
    }
`endif

    // Row 8: Always present (envcfg always in mstateen0)
    cp_envcfg: cross csrrw, senvcfg_csr, envcfg_state;

    // Row 7: Zcmt only
`ifdef ZCMT_SUPPORTED
    cp_jvt_access:    cross csrrw, jvt_csr, jvt_state;
    cp_jvt_lower_mode: cross priv_mode_s_u, csrrw, jvt_csr, jvt_state;
`endif

    // Row 12: Ssdtrig only
`ifdef SSDTRIG_SUPPORTED
    cp_context: cross csrrw, scontext_csr, context_state;
`endif

    // Row 13: Sm1p13 + Hypervisor only
`ifdef SM1P13_AND_H_SUPPORTED
    cp_p1p13: cross csrrw, p1p13_state, hedeleg_csr;
`endif

    // Row 14: Ssqosid only
`ifdef SSQOSID_SUPPORTED
    cp_srmcfg: cross csrrw, srmcfg_csr, srmcfg_state;
`endif

    // Row 15: Sctr only
`ifdef SCTR_SUPPORTED
    cp_ctr: cross csrrw, ctr_csrs, ctr_state;
`endif

endgroup

function void smstateen_sample(int hart, int issue, ins_t ins);
    Smstateen_cg.sample(ins);
endfunction
