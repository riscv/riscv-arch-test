function void zksed_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "sm4ed"     : begin
            Zksed_sm4ed_cg.sample(ins);
        end
        "sm4ks"     : begin
            Zksed_sm4ks_cg.sample(ins);
        end
    endcase
endfunction
