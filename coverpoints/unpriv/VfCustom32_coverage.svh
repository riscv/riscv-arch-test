// ---------------------
function void vfcustom32_sample(int hart, int issue, ins_t ins);

    if (get_csr_val(hart, issue, `SAMPLE_BEFORE, "vtype", "vsew") == 2) begin
        case (traceDataQ[hart][issue][0].inst_name)
            "vfadd.vf"     : begin
                VfCustom32_vfadd_vf_cg.sample(ins);
            end
            "vfadd.vv"     : begin
                VfCustom32_vfadd_vv_cg.sample(ins);
            end
            "vfclass.v"     : begin
                VfCustom32_vfclass_v_cg.sample(ins);
            end
            "vfcvt.f.x.v"     : begin
                VfCustom32_vfcvt_f_x_v_cg.sample(ins);
            end
            "vfcvt.f.xu.v"     : begin
                VfCustom32_vfcvt_f_xu_v_cg.sample(ins);
            end
            "vfcvt.rtz.x.f.v"     : begin
                VfCustom32_vfcvt_rtz_x_f_v_cg.sample(ins);
            end
            "vfcvt.rtz.xu.f.v"     : begin
                VfCustom32_vfcvt_rtz_xu_f_v_cg.sample(ins);
            end
            "vfcvt.x.f.v"     : begin
                VfCustom32_vfcvt_x_f_v_cg.sample(ins);
            end
            "vfcvt.xu.f.v"     : begin
                VfCustom32_vfcvt_xu_f_v_cg.sample(ins);
            end
            "vfdiv.vf"     : begin
                VfCustom32_vfdiv_vf_cg.sample(ins);
            end
            "vfdiv.vv"     : begin
                VfCustom32_vfdiv_vv_cg.sample(ins);
            end
            "vfmacc.vf"     : begin
                VfCustom32_vfmacc_vf_cg.sample(ins);
            end
            "vfmacc.vv"     : begin
                VfCustom32_vfmacc_vv_cg.sample(ins);
            end
            "vfmadd.vf"     : begin
                VfCustom32_vfmadd_vf_cg.sample(ins);
            end
            "vfmadd.vv"     : begin
                VfCustom32_vfmadd_vv_cg.sample(ins);
            end
            "vfmax.vf"     : begin
                VfCustom32_vfmax_vf_cg.sample(ins);
            end
            "vfmax.vv"     : begin
                VfCustom32_vfmax_vv_cg.sample(ins);
            end
            "vfmerge.vfm"     : begin
                VfCustom32_vfmerge_vfm_cg.sample(ins);
            end
            "vfmin.vf"     : begin
                VfCustom32_vfmin_vf_cg.sample(ins);
            end
            "vfmin.vv"     : begin
                VfCustom32_vfmin_vv_cg.sample(ins);
            end
            "vfmsac.vf"     : begin
                VfCustom32_vfmsac_vf_cg.sample(ins);
            end
            "vfmsac.vv"     : begin
                VfCustom32_vfmsac_vv_cg.sample(ins);
            end
            "vfmsub.vf"     : begin
                VfCustom32_vfmsub_vf_cg.sample(ins);
            end
            "vfmsub.vv"     : begin
                VfCustom32_vfmsub_vv_cg.sample(ins);
            end
            "vfmul.vf"     : begin
                VfCustom32_vfmul_vf_cg.sample(ins);
            end
            "vfmul.vv"     : begin
                VfCustom32_vfmul_vv_cg.sample(ins);
            end
            "vfmv.f.s"     : begin
                VfCustom32_vfmv_f_s_cg.sample(ins);
            end
            "vfmv.s.f"     : begin
                VfCustom32_vfmv_s_f_cg.sample(ins);
            end
            "vfmv.v.f"     : begin
                VfCustom32_vfmv_v_f_cg.sample(ins);
            end
        `ifndef ELEN32
            "vfncvt.f.f.w"     : begin
                VfCustom32_vfncvt_f_f_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.f.x.w"     : begin
                VfCustom32_vfncvt_f_x_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.f.xu.w"     : begin
                VfCustom32_vfncvt_f_xu_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.rod.f.f.w"     : begin
                VfCustom32_vfncvt_rod_f_f_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.rtz.x.f.w"     : begin
                VfCustom32_vfncvt_rtz_x_f_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.rtz.xu.f.w"     : begin
                VfCustom32_vfncvt_rtz_xu_f_w_cg.sample(ins);
            end
        `endif
        `ifndef ELEN32
            "vfncvt.x.f.w"     : begin
                VfCustom32_vfncvt_x_f_w_cg.sample(ins);
            end
        `endif
