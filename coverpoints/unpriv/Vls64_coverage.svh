        ignore_bins x0 = {x0};
    }
    cp_vl_0 : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") {
    bins zero = {0};
    }
    //////////////////////////////////////////////////////////////////////////////////
