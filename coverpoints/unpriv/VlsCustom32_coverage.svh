covergroup VlsCustom32_vsoxseg8ei64_v_cg with function sample(ins_t ins);
    option.per_instance = 0;
    cp_asm_count : coverpoint ins.ins_str == "vsoxseg8ei64.v"  iff (ins.trap == 0 )  {
        // Number of times instruction is executed
