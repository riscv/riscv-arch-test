# cover group format file for Zalasr extension
lb.aq:
    config: 
      - check ISA:=regex(.*Zalasr.*)
    mnemonics: 
      'lb.aq' : 0
    rs1: 
      <<: *all_regs_mx0
    rd: 
      <<: *all_regs
    op_comb: 
      <<: *ifmt_op_comb
    val_comb:
      'ea_align == 0' : 0
      'ea_align == 1' : 0
      'ea_align == 2' : 0
      'ea_align == 3' : 0
