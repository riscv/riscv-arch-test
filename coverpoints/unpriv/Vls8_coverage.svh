    //// end cp_custom_masked_vs2_v0////////////////////////////////////////////////

    cp_masking_edges : coverpoint mask_edges_check(ins.hart, ins.issue, ins.prev.v_wdata[0])  iff (ins.trap == 0 & ins.current.vm == 0)  {
        // Edges values of v0 (vector mask register)
