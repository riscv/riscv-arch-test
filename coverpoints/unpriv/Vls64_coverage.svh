        ignore_bins v25 = {v25};
        ignore_bins v26 = {v26};
        ignore_bins v27 = {v27};
        ignore_bins v29 = {v29};
        ignore_bins v30 = {v30};
        ignore_bins v31 = {v31};
    }

    //// end cp_vd_emul4////////////////////////////////////////////////
