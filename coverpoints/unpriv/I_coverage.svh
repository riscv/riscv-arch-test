function void i_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "add"     : begin
            I_add_cg.sample(ins);
        end
        "addi"     : begin
            I_addi_cg.sample(ins);
