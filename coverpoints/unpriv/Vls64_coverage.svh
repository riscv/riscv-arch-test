covergroup Vls64_vluxseg4ei16_v_cg with function sample(ins_t ins);
    option.per_instance = 0;
    cp_asm_count : coverpoint ins.ins_str == "vluxseg4ei16.v"  iff (ins.trap == 0 )  {
        // Number of times instruction is executed
