            end
            "vfnmacc.vv"     : begin
                VfCustom32_vfnmacc_vv_cg.sample(ins);
            end
            "vfnmadd.vf"     : begin
                VfCustom32_vfnmadd_vf_cg.sample(ins);
            end
            "vfnmadd.vv"     : begin
                VfCustom32_vfnmadd_vv_cg.sample(ins);
            end
            "vfnmsac.vf"     : begin
                VfCustom32_vfnmsac_vf_cg.sample(ins);
            end
            "vfnmsac.vv"     : begin
                VfCustom32_vfnmsac_vv_cg.sample(ins);
            end
            "vfnmsub.vf"     : begin
                VfCustom32_vfnmsub_vf_cg.sample(ins);
            end
            "vfnmsub.vv"     : begin
                VfCustom32_vfnmsub_vv_cg.sample(ins);
