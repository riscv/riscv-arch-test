`define COVER_SVNAPOT
covergroup Svnapot_cg with function sample(ins_t ins);
    option.per_instance = 0;
    `include  "coverage/RISCV_coverage_standard_coverpoints.svh"

    PTE_Svnapot_s_i: coverpoint ins.current.pte_i[63:0] {
        wildcard bins leaflvl_s = {64'b1?????????????????????????????????????????????????1000_??11?01111};
    }
    PTE_Svnapot_u_i: coverpoint ins.current.pte_i[63:0] {
        wildcard bins leaflvl_u = {64'b1?????????????????????????????????????????????????1000_??11?11111};
    }
    PTE_Svnapot_s_d: coverpoint ins.current.pte_d[63:0] {
        wildcard bins leaflvl_s = {64'b1?????????????????????????????????????????????????1000_??11?01111};
    }
    PTE_Svnapot_u_d: coverpoint ins.current.pte_d[63:0] {
        wildcard bins leaflvl_u = {64'b1?????????????????????????????????????????????????1000_??11?11111};
    }
    PTE_Svnapot_reserved_enc_s_i: coverpoint ins.current.pte_i[63:0] {
        wildcard bins illegal_xxx1 = {64'b1????????????????????????????????????????????????????1_??11?01111};
        wildcard bins illegal_xx1x = {64'b1???????????????????????????????????????????????????1?_??11?01111};
        wildcard bins illegal_x1xx = {64'b1??????????????????????????????????????????????????1??_??11?01111};
        wildcard bins illegal_0xxx = {64'b1?????????????????????????????????????????????????0???_??11?01111};
        wildcard bins illegal_PPNi = {64'b1????????????????????????????????????????1000?????????_??11?01111};
    }
    PTE_Svnapot_reserved_enc_u_i: coverpoint ins.current.pte_i[63:0] {
        wildcard bins illegal_xxx1 = {64'b1????????????????????????????????????????????????????1_??11?11111};
        wildcard bins illegal_xx1x = {64'b1???????????????????????????????????????????????????1?_??11?11111};
        wildcard bins illegal_x1xx = {64'b1??????????????????????????????????????????????????1??_??11?11111};
        wildcard bins illegal_0xxx = {64'b1?????????????????????????????????????????????????0???_??11?11111};
        wildcard bins illegal_PPNi = {64'b1????????????????????????????????????????1000?????????_??11?11111};
    }
    PTE_Svnapot_reserved_enc_s_d: coverpoint ins.current.pte_d[63:0] {
        wildcard bins illegal_xxx1 = {64'b1????????????????????????????????????????????????????1_??11?01111};
        wildcard bins illegal_xx1x = {64'b1???????????????????????????????????????????????????1?_??11?01111};
        wildcard bins illegal_x1xx = {64'b1??????????????????????????????????????????????????1??_??11?01111};
        wildcard bins illegal_0xxx = {64'b1?????????????????????????????????????????????????0???_??11?01111};
        wildcard bins illegal_PPNi = {64'b1????????????????????????????????????????1000?????????_??11?01111};
    }
    PTE_Svnapot_reserved_enc_u_d: coverpoint ins.current.pte_d[63:0] {
        wildcard bins illegal_xxx1 = {64'b1????????????????????????????????????????????????????1_??11?11111};
        wildcard bins illegal_xx1x = {64'b1???????????????????????????????????????????????????1?_??11?11111};
        wildcard bins illegal_x1xx = {64'b1??????????????????????????????????????????????????1??_??11?11111};
        wildcard bins illegal_0xxx = {64'b1?????????????????????????????????????????????????0???_??11?11111};
        wildcard bins illegal_PPNi = {64'b1????????????????????????????????????????1000?????????_??11?11111};
    }

    mode: coverpoint ins.current.csr[12'h180][63:60] {
        `ifdef SV57
            bins sv57 = {4'b1010};
        `endif
        `ifdef SV48
            bins sv48 = {4'b1001};
        `endif
        `ifdef SV39
            bins sv39 = {4'b1000};
        `endif
    }

    PageType_i: coverpoint ins.current.page_type_i {
        bins kilo = {2'b00};
    }
    PageType_d: coverpoint ins.current.page_type_d {
        bins kilo = {2'b00};
    }

    exec_acc: coverpoint ins.current.execute_access {
        bins set = {1};
    }
    read_acc: coverpoint ins.current.read_access {
        bins set = {1};
    }
    write_acc: coverpoint ins.current.write_access{
        bins set = {1};
    }

    ins_page_fault: coverpoint  ins.current.csr[12'h342][31:0] {
        bins ins_page_fault = {32'd12} iff (ins.current.trap);
    }
    load_page_fault: coverpoint  ins.current.csr[12'h342][31:0] {
        bins load_page_fault = {32'd13} iff (ins.current.trap);
    }
    store_page_fault: coverpoint  ins.current.csr[12'h342][31:0] {
        bins store_amo_page_fault = {32'd15} iff (ins.current.trap);
    }

    Svnapot_legal_enc_exec_s:  cross PTE_Svnapot_s_i, PageType_i, mode, exec_acc, priv_mode_s;
    Svnapot_legal_enc_exec_u:  cross PTE_Svnapot_u_i, PageType_i, mode, exec_acc, priv_mode_u;
    Svnapot_legal_enc_read_s:  cross PTE_Svnapot_s_d, PageType_d, mode, read_acc, priv_mode_s;
    Svnapot_legal_enc_read_u:  cross PTE_Svnapot_u_d, PageType_d, mode, read_acc, priv_mode_u;
    Svnapot_legal_enc_write_s: cross PTE_Svnapot_s_d, PageType_d, mode, write_acc, priv_mode_s;
    Svnapot_legal_enc_write_u: cross PTE_Svnapot_u_d, PageType_d, mode, write_acc, priv_mode_u;

    Svnapot_illegal_enc_exec_s:  cross PTE_Svnapot_reserved_enc_s_i, PageType_i, mode, exec_acc, ins_page_fault, priv_mode_s;
    Svnapot_illegal_enc_exec_u:  cross PTE_Svnapot_reserved_enc_u_i, PageType_i, mode, exec_acc, ins_page_fault, priv_mode_u;
    Svnapot_illegal_enc_read_s:  cross PTE_Svnapot_reserved_enc_s_d, PageType_d, mode, read_acc, load_page_fault, priv_mode_s;
    Svnapot_illegal_enc_read_u:  cross PTE_Svnapot_reserved_enc_u_d, PageType_d, mode, read_acc, load_page_fault, priv_mode_u;
    Svnapot_illegal_enc_write_s: cross PTE_Svnapot_reserved_enc_s_d, PageType_d, mode, write_acc, store_page_fault, priv_mode_s;
    Svnapot_illegal_enc_write_u: cross PTE_Svnapot_reserved_enc_u_d, PageType_d, mode, write_acc, store_page_fault, priv_mode_u;

endgroup

function void svnapot_sample(int hart, int issue, ins_t ins);
    Svnapot_cg.sample(ins);
endfunction
