covergroup Vx16_vzext_vf2_cg with function sample(ins_t ins);
    option.per_instance = 0;
    cp_asm_count : coverpoint ins.ins_str == "vzext.vf2"  iff (ins.trap == 0 )  {
        // Number of times instruction is executed
        bins count[]  = {1};
    }

    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_vext2_overlapping_vd_vs2_lmul8
    //////////////////////////////////////////////////////////////////////////////////

    // Custom coverpoints for Vector zext and sext operations (f2)

    // ensures vd updates
    // cross vtype_prev_vill_clear, vstart_zero, vl_nonzero, no_trap;
    std_vec: coverpoint {get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vill") == 0 &
                        get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vstart", "vstart") == 0 &
                        get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") != 0 &
                        ins.trap == 0
                    }
    {
        bins true = {1'b1};
    }


    vtype_lmul_2: coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vlmul") {
        bins two = {1};
    }

    vtype_lmul_4: coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vlmul") {
        bins two = {2};
    }

    vtype_lmul_8: coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vlmul") {
        bins two = {3};
    }

    vs2_vd_overlap_lmul2: coverpoint (ins.current.insn[24:21] == ins.current.insn[11:8]) {
        bins overlapping = {1'b1};
    }

    vs2_vd_overlap_lmul4: coverpoint (ins.current.insn[24:22] == ins.current.insn[11:9]) {
        bins overlapping = {1'b1};
    }

    vs2_vd_overlap_lmul8: coverpoint (ins.current.insn[24:23] == ins.current.insn[11:10]) {
        bins overlapping = {1'b1};
    }

    vs2_reg_unaligned_lmul_2: coverpoint ins.current.insn[24:20] {
        wildcard bins odd = {5'b????1};
    }

    vs2_mod4_2: coverpoint ins.current.insn[21:20] {
        bins mod4_2 = {2'b10};
    }

    vs2_mod8_4: coverpoint ins.current.insn[22:20] {
        bins mod8_4 = {3'b100};
    }

    cp_custom_vext2_overlapping_vd_vs2_lmul2:    cross std_vec, vtype_lmul_2, vs2_vd_overlap_lmul2, vs2_reg_unaligned_lmul_2;
    cp_custom_vext2_overlapping_vd_vs2_lmul4:    cross std_vec, vtype_lmul_4, vs2_vd_overlap_lmul4, vs2_mod4_2;
    cp_custom_vext2_overlapping_vd_vs2_lmul8:    cross std_vec, vtype_lmul_8, vs2_vd_overlap_lmul8, vs2_mod8_4;

    //// end cp_custom_vext2_overlapping_vd_vs2_lmul8////////////////////////////////////////////////

    cp_masking_edges : coverpoint mask_edges_check(ins.hart, ins.issue, ins.prev.v_wdata[0])  iff (ins.trap == 0 & ins.current.vm == 0)  {
        // Edges values of v0 (vector mask register)
        bins zero           = {mask_zero            };
        bins ones           = {mask_ones            };
        bins vlmaxm1ones    = {mask_vlmaxm1ones     };
        bins vlmaxd2p1ones  = {mask_vlmaxd2p1ones   };
        bins random         = {mask_random          };
    }

    //////////////////////////////////////////////////////////////////////////////////
    // cp_vd
    //////////////////////////////////////////////////////////////////////////////////

    cp_vd : coverpoint ins.get_vr_reg(ins.current.vd)  iff (ins.trap == 0 )  {
        // VD register assignment
    }

    //// end cp_vd////////////////////////////////////////////////

    cp_vl_0 : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") {
    bins zero = {0};
    }

    //////////////////////////////////////////////////////////////////////////////////
    // cp_vs2
    //////////////////////////////////////////////////////////////////////////////////

    cp_vs2 : coverpoint ins.get_vr_reg(ins.current.vs2)  iff (ins.trap == 0 )  {
        // VS2 register assignment
    }

    //// end cp_vs2////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cp_vs2_edges_emulf2
    //////////////////////////////////////////////////////////////////////////////////

    cp_vs2_edges_emulf2 : coverpoint vs_edges_check(ins.hart, ins.issue, ins.current.vs2_val, "f2")  iff (ins.trap == 0 )  {
        // Edges values of vs2 (emul = f2), assuming vl = 1
        bins zero       = {vs_zero      };   //  = {(`SEW){1'b0}},
        bins one        = {vs_one       };   //  = {(`SEW-1){1'b0}, {1'b1}},
        bins two        = {vs_two       };   //  = {(`SEW-2){1'b0}, {2'b10}},
        bins min        = {vs_min       };   //  = {{1'b1}, (`SEW-1){1'b0}},
        bins minp1      = {vs_minp1     };   //  = {{1'b1}, (`SEW-2){1'b0}, {1'b1}},
        bins max        = {vs_max       };   //  = {{1'b0}, (`SEW-1){1'b1}},
        bins maxm1      = {vs_maxm1     };   //  = {{1'b0}, (`SEW-2){1'b1}, {1'b0}},
        bins ones       = {vs_ones      };   //  = {(`SEW){1'b1}},
        bins onesm1     = {vs_onesm1    };   //  = {(`SEW-1){1'b1}, {1'b0}},
        bins walkodd    = {vs_walkodd   };   //  = {(`SEW/2){2'b10}},
        bins walkeven   = {vs_walkeven  };   //  = {(`SEW/2){2'b01}},
        bins random     = {vs_random    };   //  = {(SEW){random}}
    }

    //// end cp_vs2_edges_emulf2////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cr_vl_lmul_sew16
    //////////////////////////////////////////////////////////////////////////////////

    cp_csr_vtype_lmul_all_sew16_lmul_le_8 : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vlmul")  iff (ins.trap == 0 & get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vsew") == 1) {
        // Value of VTYPE.vlmul (vector register grouping), SEW = 16
        `ifdef LMULf4_SUPPORTED
            bins fourth = {6};
        `endif
        `ifdef LMULf2_SUPPORTED
            bins half   = {7};
        `endif
        bins one    = {0};
        bins two    = {1};
        bins four   = {2};
        bins eight  = {3};
    }

    cp_csr_vl_edges : coverpoint vl_check(ins.hart, ins.issue)  iff (ins.trap == 0 )  {
        // Edges values of VL (vector length)
        bins one        = {vl_one       };
        bins vlmax      = {vl_vlmax     };
        bins legal      = {vl_legal     };
    }

    cr_vl_lmul_sew16 : cross cp_csr_vtype_lmul_all_sew16_lmul_le_8, cp_csr_vl_edges  iff (ins.trap == 0 & get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vsew") == 1)  {
        // Cross coverage all legal LMULs for SEW = 16 and vl edges (1, random, vlmax)
    }

    //////////////////////////////////////////////////////////////////////////////////

    //// end cr_vl_lmul_sew16////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cr_vtype_agnostic
    //////////////////////////////////////////////////////////////////////////////////

    cp_csr_vtype_vta : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vta")  iff (ins.trap == 0)  {
        // Value of VTYPE.vta (vector tail agnostic)
        bins undisturbed = {0};
        bins agnostic    = {1};
    }

    cp_csr_vtype_vma : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vma")  iff (ins.trap == 0)  {
        // Value of VTYPE.vma (vector mask agnostic)
        bins undisturbed = {0};
        bins agnostic    = {1};
    }

    mask_enabled_agnostic: coverpoint ins.current.insn[25] {
        bins enabled = {1'b0};
    }

    cr_vtype_agnostic : cross cp_csr_vtype_vta,cp_csr_vtype_vma,mask_enabled_agnostic iff (ins.trap == 0 )  {
        // Cross coverage of vector tail and mask agnostic behaviors
    }

    //// end cr_vtype_agnostic////////////////////////////////////////////////

endgroup
// ---------------------
function void vx16_sample(int hart, int issue, ins_t ins);
    // Want to sample only if the SEW matches the target SEW of the file, some tests require
    // testing when vill is set, if vill=1 all other vtype bits are set to 0 so there is no
    // associated sew with these tests
    if (get_csr_val(hart, issue, `SAMPLE_BEFORE, "vtype", "vsew") == 1 ||
        get_csr_val(hart, issue, `SAMPLE_BEFORE, "vtype", "vill") == 1) begin
        case (traceDataQ[hart][issue][0].inst_name)
            "vaadd.vv"     : begin
                Vx16_vaadd_vv_cg.sample(ins);
            end
            "vaadd.vx"     : begin
                Vx16_vaadd_vx_cg.sample(ins);
            end
            "vaaddu.vv"     : begin
                Vx16_vaaddu_vv_cg.sample(ins);
            end
            "vaaddu.vx"     : begin
                Vx16_vaaddu_vx_cg.sample(ins);
            end
            "vadc.vim"     : begin
                Vx16_vadc_vim_cg.sample(ins);
            end
            "vadc.vvm"     : begin
                Vx16_vadc_vvm_cg.sample(ins);
            end
            "vadc.vxm"     : begin
                Vx16_vadc_vxm_cg.sample(ins);
            end
            "vadd.vi"     : begin
                Vx16_vadd_vi_cg.sample(ins);
            end
            "vadd.vv"     : begin
                Vx16_vadd_vv_cg.sample(ins);
            end
            "vadd.vx"     : begin
                Vx16_vadd_vx_cg.sample(ins);
            end
            "vand.vi"     : begin
                Vx16_vand_vi_cg.sample(ins);
            end
            "vand.vv"     : begin
                Vx16_vand_vv_cg.sample(ins);
            end
            "vand.vx"     : begin
                Vx16_vand_vx_cg.sample(ins);
            end
            "vasub.vv"     : begin
                Vx16_vasub_vv_cg.sample(ins);
            end
            "vasub.vx"     : begin
                Vx16_vasub_vx_cg.sample(ins);
            end
            "vasubu.vv"     : begin
                Vx16_vasubu_vv_cg.sample(ins);
            end
            "vasubu.vx"     : begin
                Vx16_vasubu_vx_cg.sample(ins);
            end
            "vcompress.vm"     : begin
                Vx16_vcompress_vm_cg.sample(ins);
            end
            "vcpop.m"     : begin
                Vx16_vcpop_m_cg.sample(ins);
            end
            "vdiv.vv"     : begin
                Vx16_vdiv_vv_cg.sample(ins);
            end
            "vdiv.vx"     : begin
                Vx16_vdiv_vx_cg.sample(ins);
            end
            "vdivu.vv"     : begin
                Vx16_vdivu_vv_cg.sample(ins);
            end
            "vdivu.vx"     : begin
                Vx16_vdivu_vx_cg.sample(ins);
            end
            "vfirst.m"     : begin
                Vx16_vfirst_m_cg.sample(ins);
            end
            "vid.v"     : begin
                Vx16_vid_v_cg.sample(ins);
            end
            "viota.m"     : begin
                Vx16_viota_m_cg.sample(ins);
            end
            "vmacc.vv"     : begin
                Vx16_vmacc_vv_cg.sample(ins);
            end
            "vmacc.vx"     : begin
                Vx16_vmacc_vx_cg.sample(ins);
            end
            "vmadc.vi"     : begin
                Vx16_vmadc_vi_cg.sample(ins);
            end
            "vmadc.vim"     : begin
                Vx16_vmadc_vim_cg.sample(ins);
            end
            "vmadc.vv"     : begin
                Vx16_vmadc_vv_cg.sample(ins);
            end
            "vmadc.vvm"     : begin
                Vx16_vmadc_vvm_cg.sample(ins);
            end
            "vmadc.vx"     : begin
                Vx16_vmadc_vx_cg.sample(ins);
            end
            "vmadc.vxm"     : begin
                Vx16_vmadc_vxm_cg.sample(ins);
            end
            "vmadd.vv"     : begin
