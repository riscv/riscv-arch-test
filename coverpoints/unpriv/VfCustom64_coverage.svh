// ---------------------
covergroup VfCustom64_vfrsqrt7_v_cg with function sample(ins_t ins);
    option.per_instance = 0;
    cp_asm_count : coverpoint ins.ins_str == "vfrsqrt7.v"  iff (ins.trap == 0 )  {
        // Number of times instruction is executed
        bins count[]  = {1};
    }
    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_FPrecSqrt_edges
    //////////////////////////////////////////////////////////////////////////////////

    FpRecSqrtEst_all_inputs_vs2_0 : coverpoint
    `ifdef COVER_VFCUSTOM16
    get_vr_element_zero(ins.hart, ins.issue, ins.current.vs2_val)[10:4]
    `endif
    `ifdef COVER_VFCUSTOM32
    get_vr_element_zero(ins.hart, ins.issue, ins.current.vs2_val)[23:17]
    `endif
    `ifdef COVER_VFCUSTOM64
    get_vr_element_zero(ins.hart, ins.issue, ins.current.vs2_val)[52:46]
    `endif
    {
        // all bins
    }


    cp_custom_FpRecSqrtEst_edges: cross std_vec, FpRecSqrtEst_all_inputs_vs2_0;

    //// end cp_custom_FPrecSqrt_edges////////////////////////////////////////////////
    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_FPrecSqrt_flag_edges
    //////////////////////////////////////////////////////////////////////////////////
    fp_flags_clear : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "fcsr", "fflags") {
            bins clear = {0};
    }

    vs1_0_reciprocal_sqrt_edges : coverpoint get_vr_element_zero(ins.hart, ins.issue, ins.current.vs1) {
        // -∞ ≤ x < -0.0   (representative negative finite: -1.0)
        `ifdef COVER_VFCUSTOM16
            // -1.0h = 0xBC00
            bins vs1_0_neg_finite = {64'h0000_0000_0000_BC00};
            // -Inf_h = 0xFC00
            bins vs1_0_neg_inf    = {64'h0000_0000_0000_FC00};
            // -0.0h = 0x8000
            bins vs1_0_neg_zero   = {64'h0000_0000_0000_8000};

            // +0.0h = 0x0000
            bins vs1_0_pos_zero   = {64'h0000_0000_0000_0000};
            // +Inf_h = 0x7C00
            bins vs1_0_pos_inf    = {64'h0000_0000_0000_7C00};
            // +1.0h = 0x3C00
            bins vs1_0_pos_finite = {64'h0000_0000_0000_3C00};

            // qNaN_h canonical = 0x7E00
            bins vs1_0_qNaN       = {64'h0000_0000_0000_7E00};
            // sNaN_h example = 0x7D00
            bins vs1_0_sNaN       = {64'h0000_0000_0000_7D00};
        `endif

        `ifdef COVER_VFCUSTOM32
            // -1.0f = 0xBF800000
            bins vs1_0_neg_finite = {64'h0000_0000_BF80_0000};
            // -Inf_f = 0xFF800000
            bins vs1_0_neg_inf    = {64'h0000_0000_FF80_0000};
            // -0.0f = 0x80000000
            bins vs1_0_neg_zero   = {64'h0000_0000_8000_0000};

            // +0.0f = 0x00000000
            bins vs1_0_pos_zero   = {64'h0000_0000_0000_0000};
            // +Inf_f = 0x7F800000
            bins vs1_0_pos_inf    = {64'h0000_0000_7F80_0000};
            // +1.0f = 0x3F800000
            bins vs1_0_pos_finite = {64'h0000_0000_3F80_0000};

            // qNaN_f canonical = 0x7FC00000
            bins vs1_0_qNaN       = {64'h0000_0000_7FC0_0000};
            // sNaN_f example = 0x7FA00000
            bins vs1_0_sNaN       = {64'h0000_0000_7FA0_0000};
        `endif

        `ifdef COVER_VFCUSTOM64
            // -1.0d = 0xBFF0000000000000
            bins vs1_0_neg_finite = {64'hBFF0_0000_0000_0000};
            // -Inf_d = 0xFFF0000000000000
            bins vs1_0_neg_inf    = {64'hFFF0_0000_0000_0000};
            // -0.0d = 0x8000000000000000
            bins vs1_0_neg_zero   = {64'h8000_0000_0000_0000};

            // +0.0d = 0x0000000000000000
            bins vs1_0_pos_zero   = {64'h0000_0000_0000_0000};
            // +Inf_d = 0x7FF0000000000000
            bins vs1_0_pos_inf    = {64'h7FF0_0000_0000_0000};
            // +1.0d = 0x3FF0000000000000
            bins vs1_0_pos_finite = {64'h3FF0_0000_0000_0000};

            // qNaN_d canonical = 0x7FF8000000000000
            bins vs1_0_qNaN       = {64'h7FF8_0000_0000_0000};
            // sNaN_d example = 0x7FF0000000000001
            bins vs1_0_sNaN       = {64'h7FF0_0000_0000_0001};
        `endif
    }

    cp_custom_FpRecSqrtEst_flag_edges: cross std_vec, vs1_0_reciprocal_sqrt_edges, fp_flags_clear;

    //// end cp_custom_FPrecSqrt_flag_edges////////////////////////////////////////////////
    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_vfp_NaN_input
    //////////////////////////////////////////////////////////////////////////////////

    vfp_NaN_input_fp_flags_clear : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "fcsr", "fflags") {
        bins clear = {0};
    }

    vs2_element0_sqNAN : coverpoint get_vr_element_zero(ins.hart, ins.issue, ins.current.vs2_val) {
        `ifdef COVER_VFCUSTOM16
            bins vs2_0_qNaN = {64'h0000_0000_0000_7E00}; // qNaN input (canonical half)
            bins vs2_0_sNaN = {64'h0000_0000_0000_7D00}; // sNaN input (half)
        `endif
        `ifdef COVER_VFCUSTOM32
            bins vs2_0_qNaN = {64'h0000_0000_7FC0_0000}; // qNaN input (canonical single)
            bins vs2_0_sNaN = {64'h0000_0000_7FA0_0000}; // sNaN input (single)
        `endif
        `ifdef COVER_VFCUSTOM64
            bins vs2_0_qNaN = {64'h7FF8_0000_0000_0000}; // qNaN input (canonical double)
            bins vs2_0_sNaN = {64'h7FF0_0000_0000_0001}; // sNaN input (double)
        `endif
    }

    cp_custom_vfp_NaN_input : cross std_vec, vfp_NaN_input_fp_flags_clear, vs2_element0_sqNAN;

    //// end cp_custom_vfp_NaN_input////////////////////////////////////////////////
    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_vfp_flags
    //////////////////////////////////////////////////////////////////////////////////

    cp_csr_fflags_vdoun : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_AFTER, "fcsr", "fflags") iff (ins.trap == 0 )  {
        // Value of FCSR.fflags
        wildcard bins NV   = (5'b0???? => 5'b1????);
        wildcard bins NV1  = (5'b1???? => 5'b1????);
        wildcard bins DZ   = (5'b?0??? => 5'b?1???);
        wildcard bins DZ1  = (5'b?1??? => 5'b?1???);
        wildcard bins OF   = (5'b??0?? => 5'b??1??);
        wildcard bins OF1  = (5'b??1?? => 5'b??1??);
        wildcard bins UF   = (5'b???0? => 5'b???1?);
        wildcard bins UF1  = (5'b???1? => 5'b???1?);
        wildcard bins NX   = (5'b????0 => 5'b????1);
        wildcard bins NX1  = (5'b????1 => 5'b????1);
    }

    mask_enabled: coverpoint ins.current.insn[25] {
        bins unmasked = {1'b0};
    }

    vfp_flags_fp_flags_clear : coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "fcsr", "fflags") {
        bins clear = {0};
    }

    vfsqrt_flag_set : coverpoint (ins.current.insn == "vfrsqrt7.v" & ins.current.vs2_val == 0) {
        bins target = {1};
    }

    vl_one: coverpoint get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") {
        //Any value between max and 1
        bins target = {1};
    }

    v0_element_1_active : coverpoint (ins.current.v0_val[0]) {
        bins target = {1};
    }

    cp_custom_vfp_flags_set : cross std_vec, cp_csr_fflags_vdoun;

    cp_custom_vfp_flags_inactive_not_set : cross std_vec, vl_one, mask_enabled, v0_element_1_active, vfsqrt_flag_set, vfp_flags_fp_flags_clear;

    //// end cp_custom_vfp_flags////////////////////////////////////////////////
    std_vec: coverpoint {get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vtype", "vill") == 0 &
                        get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vstart", "vstart") == 0 &
                        get_csr_val(ins.hart, ins.issue, `SAMPLE_BEFORE, "vl", "vl") != 0 &
                        ins.trap == 0
                    }
    {
        bins true = {1'b1};
    }
endgroup
