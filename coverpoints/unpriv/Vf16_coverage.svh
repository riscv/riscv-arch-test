        bins neg1                   = {16'hBC00};
        bins posminnorm             = {16'h0400};
        bins negmaxnorm             = {16'hFBFF};
        bins posinfinity            = {16'h7C00};
        bins neginfinity            = {16'hFC00};
        bins pos0p5                 = {16'h3800};
        bins pos1p5                 = {16'h3E00};
        bins neg2                   = {16'hC000};
        bins pi                     = {16'h4248};
        bins twoToEmax              = {16'h7800};
