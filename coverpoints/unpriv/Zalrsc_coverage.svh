function void zalrsc_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "lr.w"     : begin
            Zalrsc_lr_w_cg.sample(ins);
        end
        "sc.w"     : begin
            Zalrsc_sc_w_cg.sample(ins);
        end
`ifdef XLEN64
        "lr.d"     : begin
            Zalrsc_lr_d_cg.sample(ins);
        end
        "sc.d"     : begin
            Zalrsc_sc_d_cg.sample(ins);
        end
`endif
    endcase
endfunction
