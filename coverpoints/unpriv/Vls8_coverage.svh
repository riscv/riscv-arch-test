    // cp_vs2_edges_ls
    //////////////////////////////////////////////////////////////////////////////////

    cp_vs2_edges_ls : coverpoint vs2_ls_edges_check(ins.hart, ins.issue, ins.current.vs2_val) {
        bins zero   = {zero};
        bins random = {random_in_range};
    }

    //// end cp_vs2_edges_ls////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cp_vs3_lte29
    //////////////////////////////////////////////////////////////////////////////////

    cp_vs3_lte29 : coverpoint ins.get_vr_reg(ins.current.vs3)  iff (ins.trap == 0 )  {
