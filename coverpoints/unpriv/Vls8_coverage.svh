        bins enabled = {1'b0};
    }

    cr_vtype_agnostic_e32_emul4max : cross cp_csr_vtype_vta,cp_csr_vtype_vma,mask_enabled_agnostic iff (ins.trap == 0 )  {
        // Cross coverage of vector tail and mask agnostic behaviors
    }

    //// end cr_vtype_agnostic_e32_emul4max////////////////////////////////////////////////

endgroup
