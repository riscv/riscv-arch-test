    }

    //////////////////////////////////////////////////////////////////////////////////

    //// end cr_vl_lmul_sew16////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cr_vs2_imm_edges
    //////////////////////////////////////////////////////////////////////////////////

    cp_imm_edges_5bit : coverpoint signed'(ins.current.imm)  iff (ins.trap == 0 )  {
        bins b_0 = {0};
