function void zcd_sample(int hart, int issue, ins_t ins);

    case (traceDataQ[hart][issue][0].inst_name)
        "c.fld"     : begin
            Zcd_c_fld_cg.sample(ins);
        end
        "c.fldsp"     : begin
            Zcd_c_fldsp_cg.sample(ins);
