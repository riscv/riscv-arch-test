        bins agnostic    = {1};
    }

    not_maskable: coverpoint ins.current.insn[25] {
        // For instructions that cannot be masked (vm = 1)
        bins enabled = {1'b1};
    }

    cr_vtype_agnostic_nomask : cross cp_csr_vtype_vta,cp_csr_vtype_vma,not_maskable iff (ins.trap == 0 )  {
