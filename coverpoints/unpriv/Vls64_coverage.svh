    //////////////////////////////////////////////////////////////////////////////////

    cp_vd_emul4 : coverpoint ins.get_vr_reg(ins.current.vd) iff (ins.trap == 0) {
        // VD register assignment (widening instruction, including only registers of multiple of 4)
        ignore_bins v1 = {v1};
        ignore_bins v2 = {v2};
        ignore_bins v3 = {v3};
        ignore_bins v5 = {v5};
        ignore_bins v6 = {v6};
        ignore_bins v7 = {v7};
        ignore_bins v9 = {v9};
        ignore_bins v10 = {v10};
