    }

    //////////////////////////////////////////////////////////////////////////////////

    //// end cr_vl_lmul_e64_emul2max_sew8////////////////////////////////////////////////

    //////////////////////////////////////////////////////////////////////////////////
    // cr_vtype_agnostic_e64_emul2max
    //////////////////////////////////////////////////////////////////////////////////

