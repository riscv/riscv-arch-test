            Zca_c_addiw_cg.sample(ins);
        end
        "c.addw"     : begin
            Zca_c_addw_cg.sample(ins);
        end
        "c.ld"     : begin
            Zca_c_ld_cg.sample(ins);
        end
        "c.ldsp"     : begin
            Zca_c_ldsp_cg.sample(ins);
        end
        "c.sd"     : begin
