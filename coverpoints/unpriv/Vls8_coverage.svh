    //// end cmp_vs3_vs2_lte28////////////////////////////////////////////////

    cp_asm_count : coverpoint ins.ins_str == "vsuxseg4ei32.v"  iff (ins.trap == 0 )  {
        // Number of times instruction is executed
        bins count[]  = {1};
    }

    //////////////////////////////////////////////////////////////////////////////////
    // cp_custom_indexed_emul_data_only
    //////////////////////////////////////////////////////////////////////////////////

