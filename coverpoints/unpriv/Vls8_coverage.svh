    // cp_custom_ls_indexed
    //////////////////////////////////////////////////////////////////////////////////

    `ifdef COVER_VLS8
    vs2_element_zero_minus1_sew8 : coverpoint get_vr_element_zero(ins.hart, ins.issue, ins.current.vs2_val) {
        wildcard bins target = {64'b????????_????????_????????_11111111};
