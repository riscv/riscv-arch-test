        wildcard bins NV   = (5'b0???? => 5'b1????);
        wildcard bins NV1  = (5'b1???? => 5'b1????);
    }

    cp_custom_vfp_flags_nv : cross std_vec, cp_csr_fflags_vdoun_nv;
    `endif
`endif

