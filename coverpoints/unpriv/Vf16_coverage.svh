    //////////////////////////////////////////////////////////////////////////////////

    cmp_vs1_vs2 : coverpoint ins.get_vr_reg(ins.current.vs1)  iff (ins.current.vs1 == ins.current.vs2 & ins.trap == 0 )  {
        // Compare assignments of all 32 registers
    }

