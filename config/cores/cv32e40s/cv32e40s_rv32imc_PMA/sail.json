{
  "$schema": "/opt/riscv/share/sail-riscv/sail_riscv_config_schema.json",
  "base": {
    "xlen": 32,
    "E": false,
    "writable_misa": false,
    "writable_fiom": true,
    "writable_hpm_counters": {
      "len": 32,
      // NUM_MHPMCOUNTERS=0; no HPM counters implemented
      "value": "0x00000000"
    },
    // U-mode supported; CY/TM/IR (bits 0-2) writable, no HPM counters
    "scounteren_writable_bits": {
      "len": 32,
      "value": "0x00000007"
    },
    "xtval_nonzero": {
      // mtval hardwired to 0 (cs_registers.sv)
      "illegal_instruction": false,
      "software_breakpoint": false,
      "hardware_breakpoint": false,
      "load_address_misaligned": false,
      "load_access_fault": false,
      "load_page_fault": false,
      "samo_address_misaligned": false,
      "samo_access_fault": false,
      "samo_page_fault": false,
      "fetch_address_misaligned": false,
      "fetch_access_fault": false,
      "fetch_page_fault": false,
      "software_check": false,
      "reserved_exceptions": false
    },
    "reserved_behavior": {
      "amocas_odd_register": "AMOCAS_Illegal",
      "fcsr_rm": "Fcsr_RM_Illegal",
      "pmpcfg_write_only": "PMP_ClearPermissions",
      "xenvcfg_cbie": "Xenvcfg_ClearPermissions",
      "xtvec_mode": "Xtvec_Ignore",
      "rv32zdinx_odd_register": "Zdinx_Illegal"
    }
  },
  "memory": {
    "pmp": {
      "grain": 0,
      // PMP_NUM_REGIONS=0
      "count": 0,
      "usable_count": 0,
      "tor_supported": true,
      "na4_supported": true,
      "napot_supported": true
    },
    "misaligned": {
      // misaligned handled as split bus transactions
      "supported": true,
      "byte_by_byte": false,
      "order_decreasing": false,
      "allowed_within_exp": 0,
      "exceptions": {
        "load_store": { "None": null },
        "vector": { "None": null },
        "lrsc": "AccessFault",
        "amo": "AccessFault"
      }
    },
    "translation": {
      "dirty_update": false
    },
    "dtb_address": {
      "len": 64,
      "value": "0x1000"
    },
    "regions": [
      {
        "base": { "len": 64, "value": "0x0" },
        "size": { "len": 64, "value": "0x2000000" },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": true,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          "misaligned_exceptions": {
            "load_store": { "None": null },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": true
      },
      // IO: CLINT at 0x2000000 + simple_interrupt_generator at 0x20C0000
      {
        "base": { "len": 64, "value": "0x2000000" },
        "size": { "len": 64, "value": "0x200000" },
        "attributes": {
          "mem_type": "IOMemory",
          "cacheable": false,
          "coherent": false,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": false,
          "write_idempotent": false,
          "misaligned_exceptions": {
            "load_store": { "Some": "AlignmentException" },
            "vector": { "Some": "AlignmentException" },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      },
      // covers rvmodel virtual peripheral addresses (0x10000000, 0x20000000)
      {
        "base": { "len": 64, "value": "0x2200000" },
        "size": { "len": 64, "value": "0x5DE00000" },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          "misaligned_exceptions": {
            "load_store": { "None": null },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      }
    ]
  },
  "platform": {
    // OpenHW Group JEDEC mvendorid=0x602=1538
    "vendorid": 1538,
    // marchid=0x15 (cv32e40s_pkg.sv)
    "archid": 21,
    "impid": 0,
    "hartid": 0,
    "cache_block_size_exp": 6,
    "reservation": {
      "reservation_set_size_exp": 3,
      "require_exact_reservation_addr": false
    },
    "clint": {
      "base": 33554432,
      "size": 786432
    },
    // 0x20C0000 = CLINT base + CLINT size
    "simple_interrupt_generator": {
      "base": 34340864
    },
    "clock_frequency": 1000000000,
    "instructions_per_tick": 2,
    "wfi_is_nop": true,
    "max_time_to_wait": 0
  },
  "extensions": {
    "M": { "supported": true },
    "A": { "supported": false },
    "F": { "supported": false },
    "D": { "supported": false },
    "V": {
      "support_level": "Disabled",
