{
  "$schema": "/opt/riscv/share/sail-riscv/sail_riscv_config_schema.json",
  "base": {
    "xlen": 32,
    "E": false,
    "writable_misa": false,
    "writable_fiom": true,
    "writable_hpm_counters": {
      "len": 32,
      // Only HPM counter 3 is active (NUM_MHPMCOUNTERS=1 default)
      "value": "0x00000008"
    },
    // CV32E40P has no S-mode, so scounteren bits are read-only zero.
    "scounteren_writable_bits": {
      "len": 32,
      "value": "0x0"
    },
    // These settings control whether the specified exceptions
    // cause information to be written into the appropriate
    // `xtval` registers.
    "xtval_nonzero": {
      // mtval is hardwired to 0 in cv32e40p — all REPORT_VA_IN_MTVAL_* = false
      "illegal_instruction": false,
      "software_breakpoint": false,
      "hardware_breakpoint": false,
      "load_address_misaligned": false,
      "load_access_fault": false,
      "load_page_fault": false,
      "samo_address_misaligned": false,
      "samo_access_fault": false,
      "samo_page_fault": false,
      "fetch_address_misaligned": false,
      "fetch_access_fault": false,
      "fetch_page_fault": false,
      "software_check": false,
      "reserved_exceptions": false
    },
    "reserved_behavior": {
      "amocas_odd_register": "AMOCAS_Illegal",
      "fcsr_rm": "Fcsr_RM_Illegal",
      "pmpcfg_write_only": "PMP_ClearPermissions",
      "xenvcfg_cbie": "Xenvcfg_ClearPermissions",
      // The configuration option determines how to handle the reserved behavior `xtvec[Mode] >= 2`.
      // "Xtvec_Fatal"  – raise a Sail exception, stopping execution.
      // "Xtvec_Ignore" – use old Mode of xtvec.
      "xtvec_mode": "Xtvec_Ignore",
      "rv32zdinx_odd_register": "Zdinx_Illegal"
    }
  },
  "memory": {
    "pmp": {
      "grain": 0,
      // cv32e40p default configuration: NUM_PMP_ENTRIES=0
      "count": 0,
      "usable_count": 0,
      "tor_supported": true,
      "na4_supported": true,
      "napot_supported": true
    },
    // These settings control global support for misaligned access so they are
    // checked before address translation. `misaligned_exceptions` in
    // `regions` is checked after address translation.
    "misaligned": {
      // CV32E40P LSU handles misaligned loads/stores in hardware (splits into two
      // aligned transactions). No alignment exception is ever raised.
      "exceptions": {
        "load_store": { "None": null },
        "vector": { "None": null },
        "lrsc": "AccessFault",
        "amo": "AccessFault"
      },
      "allowed_within_exp": 0,
      "byte_by_byte": false,
      "order_decreasing": false
    },
    "translation": {
      "dirty_update": false
    },
    // Address to write DTB to (if provided).
    "dtb_address": {
      "len": 64,
      "value": "0x1000"
    },
    "regions": [
      // Main memory: code and data. Tests link from 0x80 (see link.ld).
      {
        "base": {
          "len": 64,
          "value": "0x0"
        },
        "size": {
          "len": 64,
          "value": "0x2000000"
        },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": true,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          // CV32E40P handles misaligned loads/stores in hardware; no per-region fault.
          "misaligned_exceptions": {
            "load_store": { "None": null },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": true
      },
      // IO memory: covers CLINT at 0x2000000, Sail interrupt generator at 0xC000000,
      // and the full remaining 32-bit address space. CV32E40P has all legal memory
      // (no access faults), so Sail must not fault on any address the DUT accepts.
      {
        "base": {
          "len": 64,
          "value": "0x2000000"
        },
        "size": {
          "len": 64,
          "value": "0xFE000000"
        },
        "attributes": {
          "mem_type": "IOMemory",
          "cacheable": false,
          "coherent": true,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": false,
          "write_idempotent": false,
          "misaligned_exceptions": {
            "load_store": { "None": null },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      }
    ]
  },
  "platform": {
    // OpenHW Group JEDEC: bank=0xC, offset=0x2 → mvendorid=0x602=1538
    "vendorid": 1538,
    // marchid=0x4 — verified cv32e40p_pkg.sv:528
    "archid": 4,
    // mimpid=0x0 for FPU=0 — verified cs_registers.sv:511-513
    "impid": 0,
    "hartid": 0,
    // Cache block size, specified as a power of 2.
    "cache_block_size_exp": 6,
    "reservation": {
      // Reservation set size/alignment as a power of 2. Minimum 2 on RV32.
      "reservation_set_size_exp": 3,
      // CV32E40P has no A extension so LR/SC is never executed.
      "require_exact_reservation_addr": false
    },
    "clint": {
      // This must be in a suitable memory region (see `memory.regions`).
      "base": 33554432,
      "size": 786432
    },
    // Simple MMIO device to generate interrupts for testing purposes.
    "simple_interrupt_generator": {
      // Must be 4-byte aligned and within a memory region. Size is always 0x20.
      "base": 201326592
    },
    "clock_frequency": 1000000000,
    "instructions_per_tick": 2,
    "wfi_is_nop": false,
    // Maximum time before a WFI instruction expires.
    "max_time_to_wait": 10
  },
